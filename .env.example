# .env.example
# Copy to .env and fill in values before running.
# Never commit .env — it is in .gitignore.

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api

# ── Database ───────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# In Docker Compose the hostname is the service name (postgres).
DATABASE_URL=postgresql://campuspulse:your_password@localhost:5432/campuspulse

# Used by docker-compose.yml to configure the postgres container.
# Must match the credentials in DATABASE_URL.
POSTGRES_DB=campuspulse
POSTGRES_USER=campuspulse
POSTGRES_PASSWORD=your_password

# ── Swagger (optional) ─────────────────────────────────────────────────────────
# Set SWAGGER_ENABLED=true to expose API docs at /api/docs.
# All other SWAGGER_* variables are required when SWAGGER_ENABLED=true.
SWAGGER_ENABLED=false
SWAGGER_USER=admin
SWAGGER_PASS=changeme
SWAGGER_SECURITY_NAME=bearer
SWAGGER_PATH_DOCS=api/docs
SWAGGER_PATH_JSON=api/docs-json
SWAGGER_TITLE=CampusPulse API
SWAGGER_DESCRIPTION=Campus Event Aggregation Platform API
SWAGGER_VERSION=1.0
SWAGGER_TAG_NAME=events
SWAGGER_TAG_DESC=Event management endpoints

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/apis/credentials
# Add the callback URL as an authorised redirect URI.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── JWT (asymmetric ES256) ────────────────────────────────────────────────────
# Generate a key pair once with: pnpm keys:generate
# On Render: add both files under Secret Files (/etc/secrets/private.pem etc.)
# then copy their contents into these env vars.
#
# Local dev: run `pnpm keys:generate` — keys/private.pem and keys/public.pem
# are written to the project root and read automatically.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
