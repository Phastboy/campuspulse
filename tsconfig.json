{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@domain": [
        "src/domain"
      ],
      "@domain/*": [
        "src/domain/*"
      ],
      "@ports": [
        "src/ports"
      ],
      "@ports/*": [
        "src/ports/*"
      ],
      "@dto": [
        "src/dto"
      ],
      "@dto/*": [
        "src/dto/*"
      ],
      "@services": [
        "src/services"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@controllers": [
        "src/controllers"
      ],
      "@controllers/*": [
        "src/controllers/*"
      ],
      "@infrastructure": [
        "src/infrastructure"
      ],
      "@infrastructure/*": [
        "src/infrastructure/*"
      ],
      "@mappers": [
        "src/mappers"
      ],
      "@mappers/*": [
        "src/mappers/*"
      ],
      "@rules": [
        "src/rules"
      ],
      "@rules/*": [
        "src/rules/*"
      ],
      "@similarity": [
        "src/similarity"
      ],
      "@similarity/*": [
        "src/similarity/*"
      ],
      "@helpers": [
        "src/helpers"
      ],
      "@helpers/*": [
        "src/helpers/*"
      ],
      "@common": [
        "src/common"
      ],
      "@common/*": [
        "src/common/*"
      ],
      "@configs": [
        "src/configs"
      ],
      "@configs/*": [
        "src/configs/*"
      ],
      "@modules": [
        "src/modules"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@application": [
        "src/application"
      ],
      "@application/*": [
        "src/application/*"
      ]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
